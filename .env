# ─── Local SQLite (default for development) ──────────────────────
# Used when TURSO_DATABASE_URL is NOT set. Falls back to file-based SQLite.
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Turso (libSQL) — uncomment + fill in after `turso db create` ─
# When these are set, Turso is used INSTEAD of the local SQLite file.
# Get the URL via:  turso db show freshmart-prod --url
# Get the token via: turso db tokens create freshmart-prod
# TURSO_DATABASE_URL=libsql://freshmart-prod-<your-handle>.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...
