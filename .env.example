# ============================================================
# Fresh Mart London — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in the values you need.
#
# Two database backends are supported, selected at runtime:
#   1. TURSO (libSQL) — recommended for production / Vercel
#   2. SQLite file — local development only
# If TURSO_DATABASE_URL is set, Turso is used. Otherwise, SQLite is used.
# ============================================================

# ─── Local SQLite (default for development) ──────────────────────
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Turso (libSQL) — production / Vercel ────────────────────────
# 1. Install Turso CLI:  curl -sSfL https://get.tur.so/install.sh | bash
# 2. Sign in:            turso auth signup
# 3. Create DB:          turso db create freshmart-prod --location lhr1
# 4. Get URL:            turso db show freshmart-prod --url
# 5. Get token:          turso db tokens create freshmart-prod
# 6. Push schema:        npx prisma db push
# 7. Seed:               npx tsx prisma/seed.ts
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Auth ────────────────────────────────────────────────────────
# Used to sign JWT session tokens. MUST be at least 32 chars random.
# Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-secret-min-32-chars-please

# ─── App URL ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
