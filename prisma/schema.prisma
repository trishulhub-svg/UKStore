// ============================================================
// Fresh Mart London - Comprehensive Prisma Schema
// SQLite for local dev (will switch to PostgreSQL later)
// Includes all models needed for the full grocery store app
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────
// SQLite stores enums as strings; Prisma still validates them

enum Role {
  CUSTOMER
  DRIVER
  PICKER
  OWNER
  MANAGER
}

enum OrderStatus {
  placed
  picking
  ready
  out_for_delivery
  delivered
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum SettingCategory {
  integrations
  delivery
  notifications
  general
}

enum DiscountType {
  percentage
  fixed_amount
}

// ─── Models ───────────────────────────────────────────────────

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  name                 String?
  passwordHash         String?
  phone                String?
  role                 Role     @default(CUSTOMER)
  avatarUrl            String?
  isActive             Boolean  @default(true)
  mustResetPassword    Boolean  @default(false)  // Force password reset on next login (used for new employee accounts)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  addresses       Address[]
  orders          Order[]       @relation("CustomerOrders")
  drivenOrders    Order[]       @relation("DriverOrders")
  favourites      Favourite[]
  notifications   Notification[]
  driverProfile   DriverProfile?
  attendanceLogs  AttendanceLog[]
  shifts          Shift[]       @relation("StaffShifts")
  employeeProfile EmployeeProfile?
  sessions        Session[]
  featurePermission EmployeeFeaturePermission?
  orderStatusChanges OrderStatusLog[] @relation("OrderStatusChanges")

  @@map("users")
}

model Store {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  address              String
  latitude             Float
  longitude            Float
  phone                String?
  email                String?
  logoUrl              String?  // Custom store logo (data URL or external URL). Used in navbar, footer, favicon, admin shell.
  defaultBanner1Url    String?  // First default banner shown on the customer homepage when no promotional/normal banners are uploaded
  defaultBanner2Url    String?  // Second default banner shown on the customer homepage when no promotional/normal banners are uploaded
  baseDeliveryFee      Float    @default(3.50)
  perKmCharge          Float    @default(0.50)
  freeDeliveryThreshold Float   @default(20.00)
  deliveryRadiusKm     Float    @default(5.00)
  isActive             Boolean  @default(true)
  isOpen               Boolean  @default(true)
  openingHours         String?  // JSON: {"mon":{"open":"08:00","close":"20:00"},...}
  bankHolidayMode      String   @default("auto_close") // auto_close, reduced_hours, normal
  notificationTemplate String?  // JSON: {"delivery":"Your order is on the way!",...}
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  categories     Category[]
  products       Product[]
  orders         Order[]
  settings       StoreSetting[]
  deliveryZones  DeliveryZone[]
  promotions     Promotion[]
  expenses       Expense[]
  bankHolidays   BankHoliday[]
  banners        Banner[]

  @@map("stores")
}

model Category {
  id          String    @id @default(cuid())
  storeId     String
  name        String
  slug        String
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  // Relations
  store    Store     @relation(fields: [storeId], references: [id])
  parent   Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@unique([storeId, slug])
  @@map("categories")
}

model Product {
  id                    String   @id @default(cuid())
  storeId               String
  categoryId            String
  name                  String
  slug                  String
  description           String?
  price                 Float
  originalPrice         Float?   // For discount display: if set, shows as crossed-out original price
  vatRate               Float    @default(0.0)
  isHfss                Boolean  @default(false)
  isAgeRestricted       Boolean  @default(false)  // UK Challenge 25 — alcohol, tobacco, knives, solvents, etc.
  minimumAge            Int      @default(0)      // 0 = no restriction, 16 = energy drinks, 18 = alcohol/tobacco/knives, 21 = some US items
  imageUrl              String?
  images                String?  // JSON array of additional image URLs for gallery
  barcode               String?
  brand                 String?  // Brand name for customer filters (e.g., "Amul", "Coca-Cola")
  unit                  String   @default("each")
  weightKg              Float?
  volumeLitres          Float?
  aisle                 String?  // e.g., "A1", "B3"
  minStockThreshold     Int      @default(5)
  substituteProductId   String?  // FK to alternative product
  isAvailable           Boolean  @default(true)
  stockQuantity         Int      @default(0)
  isFeatured            Boolean  @default(false)
  rating                Float    @default(0)    // Average rating (0-5)
  reviewCount           Int      @default(0)    // Total number of reviews
  sortOrder             Int      @default(0)
  expiryDate            DateTime?  // Hard expiry — product is unsafe to sell after this date (auto-moves to wastage)
  bestBeforeDate        DateTime?  // Best-before — quality degrades but still saleable; advisory only
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  store               Store        @relation(fields: [storeId], references: [id])
  category            Category     @relation(fields: [categoryId], references: [id])
  orderItems          OrderItem[]
  favourites          Favourite[]
  substituteProduct   Product?     @relation("ProductSubstitutes", fields: [substituteProductId], references: [id])
  substitutedBy       Product[]    @relation("ProductSubstitutes")
  wastageLogs         WastageLog[]

  @@unique([storeId, slug])
  @@map("products")
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  label        String?
  addressLine1 String
  addressLine2 String?
  city         String
  postcode     String
  latitude     Float?
  longitude    Float?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  user  User   @relation(fields: [userId], references: [id])
  orders Order[]

  @@map("addresses")
}

model Order {
  id                   String        @id @default(cuid())
  storeId              String
  customerId           String
  driverId             String?
  addressId            String
  status               OrderStatus   @default(placed)
  subtotal             Float
  vatAmount            Float
  deliveryFee          Float
  total                Float
  stripeSessionId      String?
  stripePaymentIntentId String?
  paymentStatus        PaymentStatus @default(pending)
  paymentMethod        String?       // 'stripe', 'cash', 'bank_transfer'
  deliverySlot         DateTime?
  notes                String?
  hasChallenge25       Boolean       @default(false)
  challenge25Verified  Boolean       @default(false)
  batchGroup           String?       // For order batching by postcode area
  packedAt             DateTime?
  dispatchedAt         DateTime?
  deliveredAt          DateTime?
  deliveryPhotoUrl     String?
  bankTransferRef      String?
  bankTransferVerified Boolean       @default(false)
  promotionId          String?       // Applied promotion
  discountAmount       Float         @default(0)   // Discount applied from promotion
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  store     Store      @relation(fields: [storeId], references: [id])
  customer  User       @relation("CustomerOrders", fields: [customerId], references: [id])
  driver    User?      @relation("DriverOrders", fields: [driverId], references: [id])
  address   Address    @relation(fields: [addressId], references: [id])
  items     OrderItem[]
  statusLogs OrderStatusLog[]

  @@map("orders")
}

/// Audit trail for order status changes.
/// Every status transition (placed → picking → ready → out_for_delivery → delivered)
/// is recorded here with the user who made the change, timestamp, and optional note.
model OrderStatusLog {
  id          String   @id @default(cuid())
  orderId     String
  fromStatus  String   // Previous status (OrderStatus enum value as string)
  toStatus    String   // New status (OrderStatus enum value as string)
  changedById String   // User ID of the admin/driver/picker who made the change
  note        String?  // Optional note (e.g., "Driver assigned: John Smith")
  createdAt   DateTime @default(now())

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User  @relation("OrderStatusChanges", fields: [changedById], references: [id])

  @@index([orderId, createdAt])
  @@map("order_status_logs")
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  productId            String
  productName          String
  quantity             Int
  unitPrice            Float
  vatRate              Float
  vatAmount            Float
  subtotal             Float
  substitutePreference String?  // 'closest_match' | 'do_not_substitute'
  substitutedWith      String?  // product ID
  picked               Boolean  @default(false)

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model StoreSetting {
  id          String          @id @default(cuid())
  storeId     String
  key         String
  value       String          @default("")
  isSecret    Boolean         @default(true)
  category    SettingCategory @default(integrations)
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, key])
  @@map("store_settings")
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favourites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'order_update', 'promotion', 'system', etc.
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DriverProfile {
  id                    String             @id @default(cuid())
  userId                String             @unique
  vehicleType           String?            // 'bicycle', 'motorcycle', 'car', 'van'
  vehicleReg            String?
  nationalInsuranceNumber String?
  rightToWorkUrl        String?
  drivingLicenseUrl     String?
  verificationStatus    VerificationStatus @default(pending)
  verifiedBy            String?
  verifiedAt            DateTime?
  rejectionReason       String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_profiles")
}

model DeliveryZone {
  id            String   @id @default(cuid())
  storeId       String
  name          String
  postcodes     String   // JSON array of postcode strings, e.g. '["SE1","SE2"]'
  deliveryFee   Float    @default(0)
  minimumOrder  Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("delivery_zones")
}

model Promotion {
  id                    String       @id @default(cuid())
  storeId               String
  name                  String
  description           String?
  discountType          DiscountType
  discountValue         Float
  startDate             DateTime
  endDate               DateTime
  minimumOrderValue     Float        @default(0)
  usageLimit            Int?         // Max total uses (null = unlimited)
  usedCount             Int          @default(0)
  appliesToCategoryIds  String?      // JSON array of category IDs
  excludesHfss          Boolean      @default(false)
  isActive              Boolean      @default(true)
  code                  String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("promotions")
}

// ─── New Models for Requirements ────────────────────────────────

model AttendanceLog {
  id          String   @id @default(cuid())
  userId      String
  type        String   // 'clock_in' | 'clock_out'
  ipAddress   String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attendance_logs")
}

model Shift {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  startTime   String   // "08:00" — required if manualHours is null
  endTime     String   // "16:00" — required if manualHours is null
  manualHours Float?   // Optional total hours (alternative to start/end). When set, takes precedence for payroll.
  role        String   // 'picker', 'driver', 'manager'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation("StaffShifts", fields: [userId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

model WastageLog {
  id          String   @id @default(cuid())
  productId   String
  quantity    Int
  reason      String   // 'expired', 'damaged', 'spoiled', 'other'
  notes       String?
  loggedBy    String   // userId
  createdAt   DateTime @default(now())

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("wastage_logs")
}

model Expense {
  id          String   @id @default(cuid())
  storeId     String
  category    String   // 'electricity', 'rent', 'packaging', 'fuel', 'other'
  description String
  amount      Float
  date        DateTime
  receiptUrl  String?
  createdAt   DateTime @default(now())

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model BankHoliday {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  date        DateTime
  mode        String   @default("auto_close") // 'auto_close', 'reduced_hours', 'normal'
  createdAt   DateTime @default(now())

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("bank_holidays")
}

model Banner {
  id           String   @id @default(cuid())
  storeId      String
  title        String?
  imageUrl     String
  linkUrl      String?  // URL to navigate on click (e.g., "/catalog?category=dairy-eggs")
  linkCategory String?  // Category slug for quick link
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("banners")
}

model EmployeeProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  salary          Float?   // Monthly salary
  wageRate        Float?   // Hourly/daily wage rate
  wageType        String?  // 'monthly', 'hourly', 'daily'
  bankName        String?
  bankAccountNo   String?
  bankSortCode    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

// ─── Active Session Tracking ────────────────────────────────────
// Used to enforce device-login limits:
//   - OWNER (admin): 1 device maximum — new login revokes all prior sessions
//   - DRIVER / PICKER (employees): 2 devices max — 1 mobile + 1 desktop
//   - CUSTOMER: unlimited (sessions are still recorded for audit but not capped)
//
// The session row is created on login and deleted on logout / revocation.
// `getServerUser()` validates the `sid` in the JWT against this table to
// support immediate revocation.
model Session {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   // sha256(payload.signature) — for identification only
  deviceType  String   @default("unknown")  // 'mobile' | 'desktop' | 'tablet' | 'unknown'
  deviceName  String?  // Human-readable summary e.g. "Chrome on iPhone"
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  expiresAt   DateTime

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ─── Employee Feature Permissions ───────────────────────────────
// Per-employee feature access toggles. The owner (admin) chooses which
// features each employee (MANAGER / DRIVER / PICKER) can access.
//
// If no row exists for a user → ALL features are enabled (default open).
// If a row exists → only the listed feature keys are accessible.
//
// Feature keys are defined in src/lib/feature-permissions.ts (FEATURE_CATALOG).
model EmployeeFeaturePermission {
  id        String   @id @default(cuid())
  userId    String   @unique
  features  String   @default("[]")  // JSON array of feature keys, e.g. '["kanban","orders"]'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_feature_permissions")
}
